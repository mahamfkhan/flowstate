xt":"early bedtime","colId":"ongoing"},{"text":"C-section exercises","colId":"ongoing"}],"20":[{"text":"firm up vacation plans","colId":"mit"},{"text":"animo planning","colId":"ongoing"}],"21":[{"text":"reading","colId":"ongoing"}]},"2026-07-07":{"15":[],"16":[],"17":[{"text":"schengen application","colId":"mit"},{"text":"firm up vacation plans with simran","colId":"mit"}],"18":[{"text":"amazon return","colId":"mit"},{"text":"arezzo return","colId":"mit"},{"text":"lalarukh payment and delivery","colId":"mit"},{"text":"baby dinner","colId":"braindump"}],"19":[{"text":"Natasha £200","colId":"pending"},{"text":"early bedtime","colId":"ongoing"}],"20":[{"text":"nick kelsey wedding","colId":"quickwins"}],"21":[{"text":"parasol decision after blinds visit","colId":"mit"}],"22":[{"text":"reading","colId":"ongoing"}]}},"stickyNotes":[{"id":"note_1782913271924","front":"why is association not causation?","back":"association E[Y(1)] - E[Y(0)] can be defined as E[Y(1) - Y(0) | T = 1] + {E[Y(0)|T=1] - E[Y(0)|T=0]}, \n\nwhere\n\nE[Y(1) - Y(0) | T = 1] is the ATT\n\nand {E[Y(0)|T=1] - E[Y(0)|T=0]}\n\nis the bias term"},{"id":"note_1782913354107","front":"can we know the individual treatment effect?","back":"due to the fundamental problem of causal inference, we can never know the individual treatment effect because we only observe one of the potential outcomes"},{"id":"note_1782913395673","front":"what are potential outcomes?","back":"an individual (i) treatment effect would be defined as Yi(1) - Yi(0) where 1 is received treatment and 0 is they didn't"},{"id":"note_1782913477691","front":"what is the average treatment effect?","back":"the expected value of the treatment effect E[Y(1) - Y0)]\n\nimportantly, it is NOT the average of E[Y(1)] - E[Y(0)]; that is association, not causation"},{"id":"note_1782913496758","front":"what is the average treatment effect on the treated?","back":"ATT is the expected value of the treatment effect given treatment = 1, i.e. E[Y(1) - Y(0) | T=1]"},{"id":"note_1782913698608","front":"what is bias in layperson's terms?","back":"how the treated and untreated (control) differ before the treatment, in the case where none of them has received the treatment, i.e. irrespective of the treatment\n\nmathematically, we obtain the bias if we set everyone to not receive the treatment"},{"id":"note_1782914035659","front":"when does association become causation?","back":"when the bias term becomes zero, i.e. E[Y(0)|T=1] - E[Y(0)|T=0] means treatment and control group are comparable before the treatment\n\nin this case, the difference in means BECOMES the causal effect, ATT"},{"id":"note_1782914398477","front":"how does randomisation annihilate bias?","back":"by making the POTENTIAL outcomes independent of the treatment \n\n(Y0, Y1) are independent of T\n\nwe aren't talking about outcomes, we are talking about potential outcomes\n\nso, randomization gives us a way to use a simple difference in means between treatment and control and call that the treatment effect"},{"id":"note_1782914766893","front":"how do you sanity check randomisation?","back":"a good sanity check to see if the randomisation was done right (or if you are looking at the correct data) is to check if the treated are equal to the untreated in pre-treatment variables"},{"id":"note_1782914832510","front":"what is Moivre's equation?","back":"SE = sigma (SD) / sqrt(n)\n\nas the sample size grows, the average score becomes more and more precise\n\nwe are talking about generating an averages from sampling multiple times, where each sample can be big or small\n\nvariance shrinks as the sample size increases"},{"id":"note_1782915463491","front":"what is a confidence interval?","back":"with the standard error, we can create an interval that will contain the true mean 95% of the time."},{"id":"note_1782916317430","front":"how is z statistic computed","back":"By subtracting the mean and dividing by the standard error of the mean, which makes it comparable to the standard normal distribution. 95% interval at 1.96 standard deviation away from the mean of the standard normal ."}],"calendarLog":{"2026-07-02":[{"id":"ce_1783007552842","title":"Animo baby class","color":"#e08a52","catId":"cal_work"},{"id":"ce_1783008952914","title":"Hydration booster","catId":"cal_work","color":"#e08a52"},{"id":"ce_1783008839198","title":"Verify Frame subscription cancellation - May 2026","catId":"cal_work","color":"#e08a52"},{"id":"ce_1783008188377","title":"Baby breakfast - cheese omelette","catId":"cal_health","color":"#8fae7f"},{"id":"ce_1783007560433","title":"Baby lunch & cooking - fish and sweet potato","color":"#8fae7f","catId":"cal_health"},{"id":"ce_1783007748833","title":"Baby naptime - 1.5 hours","color":"#8fae7f","catId":"cal_health"},{"id":"ce_1783007753700","title":"Baby naptime 2","color":"#8fae7f","catId":"cal_health"},{"id":"ce_1783108663735","title":"Gave £100 sadaqah for baby","catId":"cal_health","color":"#8fae7f"},{"id":"ce_1783008320284","title":"Set up new baby mattress","catId":"cal_health","color":"#8fae7f"},{"id":"ce_1783108654989","title":"Slept particularly badly","catId":"cal_health","color":"#8fae7f"},{"id":"ce_1783009468376","title":"Track two baby naps on Huckleberry","catId":"cal_health","color":"#8fae7f"},{"id":"ce_1783009893882","title":"IHI drop-off","catId":"cal_personal","color":"#7ba0b5"},{"id":"ce_1783007794022","title":"Wish Rozemun","color":"#7ba0b5","catId":"cal_personal"},{"id":"ce_1783030441885","title":"App dev","catId":"calcat_1783007931900","color":"#a8453a"},{"id":"ce_1783007733516","title":"Causal inference practice","color":"#a8453a","catId":"calcat_1783007931900"},{"id":"ce_1783007742849","title":"Schedule Preply interview","color":"#a8453a","catId":"calcat_1783007931900"},{"id":"ce_1783108787966","title":"Call Riya","catId":"calcat_1783008021166","color":"#7a4550"},{"id":"ce_1783008347884","title":"Journaling","catId":"calcat_1783008021166","color":"#7a4550"},{"id":"ce_1783008926068","title":"Moistur